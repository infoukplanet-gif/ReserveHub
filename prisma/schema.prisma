generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// テナント（事業者）
// ==========================================

model Tenant {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String   @db.VarChar(100)
  slug                 String   @unique @db.VarChar(50)
  email                String   @db.VarChar(255)
  phone                String?  @db.VarChar(20)
  postalCode           String?  @map("postal_code") @db.VarChar(10)
  address              String?  @db.Text
  latitude             Decimal? @db.Decimal(10, 7)
  longitude            Decimal? @db.Decimal(10, 7)
  logoUrl              String?  @map("logo_url") @db.Text
  description          String?  @db.Text
  plan                 String   @default("free") @db.VarChar(20)
  planExpiresAt        DateTime? @map("plan_expires_at") @db.Timestamptz()
  stripeCustomerId     String?  @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?  @map("stripe_subscription_id") @db.VarChar(255)
  trialEndsAt          DateTime? @map("trial_ends_at") @db.Timestamptz()
  dashboardTheme       String   @default("flat") @map("dashboard_theme") @db.VarChar(30)
  isListedOnPlatform   Boolean  @default(false) @map("is_listed_on_platform")
  symptoms             String[] @default([])
  timezone             String   @default("Asia/Tokyo") @db.VarChar(50)
  bookingBufferMinutes Int      @default(0) @map("booking_buffer_minutes")
  cancelDeadlineHours  Int      @default(24) @map("cancel_deadline_hours")
  bookingDeadlineHours Int      @default(1) @map("booking_deadline_hours")
  maxFutureDays        Int      @default(60) @map("max_future_days")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  staff            Staff[]
  menuCategories   MenuCategory[]
  menus            Menu[]
  customers        Customer[]
  customerTags     CustomerTag[]
  carteTemplates   CarteTemplate[]
  ticketTemplates  TicketTemplate[]
  purchasedTickets PurchasedTicket[]
  reservations     Reservation[]
  businessHours    BusinessHour[]
  specialDates     SpecialDate[]
  hpSetting        HpSetting?
  hpPages          HpPage[]
  blogPosts        BlogPost[]
  notificationLogs NotificationLog[]
  followUpRules    FollowUpRule[]
  lineConfig       LineConfig?
  chatMessages     ChatMessage[]
  reviews          Review[]
  platformBoosts   PlatformBoost[]

  @@map("tenants")
}

// ==========================================
// スタッフ
// ==========================================

model Staff {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  name           String   @db.VarChar(100)
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  role           String   @default("staff") @db.VarChar(20)
  avatarUrl      String?  @map("avatar_url") @db.Text
  bio            String?  @db.Text
  nominationFee  Int      @default(0) @map("nomination_fee")
  isActive       Boolean  @default(true) @map("is_active")
  displayOrder   Int      @default(0) @map("display_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMenus   StaffMenu[]
  reservations Reservation[]
  carteRecords CarteRecord[]

  @@index([tenantId])
  @@map("staff")
}

// ==========================================
// メニュー
// ==========================================

model MenuCategory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menus  Menu[]

  @@map("menu_categories")
}

model Menu {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  durationMinutes Int      @map("duration_minutes")
  bufferMinutes   Int      @default(0) @map("buffer_minutes")
  basePrice       Int      @map("base_price")
  imageUrl        String?  @map("image_url") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category            MenuCategory?       @relation(fields: [categoryId], references: [id])
  pricingRules        PricingRule[]
  menuOptions         MenuOption[]
  staffMenus          StaffMenu[]
  reservations        Reservation[]
  ticketTemplateMenus TicketTemplateMenu[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("menus")
}

model PricingRule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId    String   @map("menu_id") @db.Uuid
  ruleType  String   @map("rule_type") @db.VarChar(20)
  dayOfWeek Int[]    @map("day_of_week")
  timeFrom  String?  @map("time_from") @db.VarChar(5)
  timeTo    String?  @map("time_to") @db.VarChar(5)
  price     Int
  label     String?  @db.VarChar(50)
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@map("pricing_rules")
}

model MenuOption {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId          String   @map("menu_id") @db.Uuid
  name            String   @db.VarChar(200)
  price           Int
  durationMinutes Int      @default(0) @map("duration_minutes")
  isRequired      Boolean  @default(false) @map("is_required")
  maxSelections   Int      @default(1) @map("max_selections")
  displayOrder    Int      @default(0) @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  menu               Menu                @relation(fields: [menuId], references: [id], onDelete: Cascade)
  reservationOptions ReservationOption[]

  @@index([menuId])
  @@map("menu_options")
}

model StaffMenu {
  staffId String @map("staff_id") @db.Uuid
  menuId  String @map("menu_id") @db.Uuid

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([staffId, menuId])
  @@map("staff_menus")
}

// ==========================================
// 顧客
// ==========================================

model Customer {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  name         String    @db.VarChar(100)
  nameKana     String?   @map("name_kana") @db.VarChar(100)
  email        String?   @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  birthDate    DateTime? @map("birth_date") @db.Date
  gender       String?   @db.VarChar(10)
  memo         String?   @db.Text
  lineUserId   String?   @map("line_user_id") @db.VarChar(100)
  totalVisits  Int       @default(0) @map("total_visits")
  totalRevenue Int       @default(0) @map("total_revenue")
  lastVisitAt  DateTime? @map("last_visit_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagAssignments   CustomerTagAssignment[]
  carteRecords     CarteRecord[]
  purchasedTickets PurchasedTicket[]
  reservations     Reservation[]

  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@map("customers")
}

model CustomerTag {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  name     String @db.VarChar(50)
  color    String @default("#3B82F6") @db.VarChar(7)

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments CustomerTagAssignment[]

  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId String @map("customer_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tag_assignments")
}

// ==========================================
// カルテ
// ==========================================

model CarteTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields  CarteField[]
  records CarteRecord[]

  @@map("carte_templates")
}

model CarteField {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   String  @map("template_id") @db.Uuid
  name         String  @db.VarChar(100)
  fieldType    String  @map("field_type") @db.VarChar(20)
  options      Json?
  isRequired   Boolean @default(false) @map("is_required")
  displayOrder Int     @default(0) @map("display_order")

  template CarteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("carte_fields")
}

model CarteRecord {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  reservationId String?  @map("reservation_id") @db.Uuid
  templateId    String   @map("template_id") @db.Uuid
  staffId       String?  @map("staff_id") @db.Uuid
  data          Json
  memo          String?  @db.Text
  recordedAt    DateTime @default(now()) @map("recorded_at") @db.Timestamptz()
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reservation Reservation?  @relation(fields: [reservationId], references: [id])
  template    CarteTemplate @relation(fields: [templateId], references: [id])
  staff       Staff?        @relation(fields: [staffId], references: [id])

  @@index([customerId])
  @@index([reservationId])
  @@map("carte_records")
}

// ==========================================
// 回数券
// ==========================================

model TicketTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(200)
  totalCount  Int      @map("total_count")
  price       Int
  validMonths Int      @map("valid_months")
  isOnSale    Boolean  @default(true) @map("is_on_sale")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetMenus      TicketTemplateMenu[]
  purchasedTickets PurchasedTicket[]

  @@map("ticket_templates")
}

model TicketTemplateMenu {
  ticketTemplateId String @map("ticket_template_id") @db.Uuid
  menuId           String @map("menu_id") @db.Uuid

  ticketTemplate TicketTemplate @relation(fields: [ticketTemplateId], references: [id], onDelete: Cascade)
  menu           Menu           @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([ticketTemplateId, menuId])
  @@map("ticket_template_menus")
}

model PurchasedTicket {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  customerId       String   @map("customer_id") @db.Uuid
  ticketTemplateId String   @map("ticket_template_id") @db.Uuid
  remainingCount   Int      @map("remaining_count")
  purchasedAt      DateTime @default(now()) @map("purchased_at") @db.Timestamptz()
  expiresAt        DateTime @map("expires_at") @db.Timestamptz()
  status           String   @default("active") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ticketTemplate TicketTemplate              @relation(fields: [ticketTemplateId], references: [id])
  ticketUsages   ReservationTicketUsage[]

  @@index([customerId])
  @@index([tenantId])
  @@index([status])
  @@map("purchased_tickets")
}

// ==========================================
// 予約
// ==========================================

model Reservation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  staffId        String?  @map("staff_id") @db.Uuid
  menuId         String   @map("menu_id") @db.Uuid
  startsAt       DateTime @map("starts_at") @db.Timestamptz()
  endsAt         DateTime @map("ends_at") @db.Timestamptz()
  menuPrice      Int      @map("menu_price")
  optionPrice    Int      @default(0) @map("option_price")
  nominationFee  Int      @default(0) @map("nomination_fee")
  totalPrice     Int      @map("total_price")
  status         String   @default("confirmed") @db.VarChar(20)
  cancelReason   String?  @map("cancel_reason") @db.Text
  memo           String?  @db.Text
  source         String   @default("web") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer                  @relation(fields: [customerId], references: [id])
  staff        Staff?                    @relation(fields: [staffId], references: [id])
  menu         Menu                      @relation(fields: [menuId], references: [id])
  options      ReservationOption[]
  ticketUsages ReservationTicketUsage[]
  carteRecords CarteRecord[]

  @@index([tenantId, startsAt])
  @@index([customerId])
  @@index([staffId, startsAt])
  @@index([status])
  @@map("reservations")
}

model ReservationOption {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String @map("reservation_id") @db.Uuid
  menuOptionId  String @map("menu_option_id") @db.Uuid
  price         Int

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  menuOption  MenuOption  @relation(fields: [menuOptionId], references: [id])

  @@map("reservation_options")
}

model ReservationTicketUsage {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId     String   @map("reservation_id") @db.Uuid
  purchasedTicketId String   @map("purchased_ticket_id") @db.Uuid
  usedAt            DateTime @default(now()) @map("used_at") @db.Timestamptz()

  reservation     Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  purchasedTicket PurchasedTicket @relation(fields: [purchasedTicketId], references: [id])

  @@map("reservation_ticket_usages")
}

// ==========================================
// 営業時間
// ==========================================

model BusinessHour {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  dayOfWeek Int     @map("day_of_week")
  openTime  String  @map("open_time") @db.VarChar(5)
  closeTime String  @map("close_time") @db.VarChar(5)
  isClosed  Boolean @default(false) @map("is_closed")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@map("business_hours")
}

model SpecialDate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  date      DateTime @db.Date
  isClosed  Boolean  @default(true) @map("is_closed")
  openTime  String?  @map("open_time") @db.VarChar(5)
  closeTime String?  @map("close_time") @db.VarChar(5)
  label     String?  @db.VarChar(100)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@map("special_dates")
}

// ==========================================
// ホームページ
// ==========================================

model HpSetting {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @unique @map("tenant_id") @db.Uuid
  template        String   @default("simple") @db.VarChar(50)
  uiTheme         String   @default("flat") @map("ui_theme") @db.VarChar(30)
  primaryColor    String   @default("#2563EB") @map("primary_color") @db.VarChar(7)
  secondaryColor  String   @default("#1D4ED8") @map("secondary_color") @db.VarChar(7)

  // ナビゲーション
  navType         String   @default("header") @map("nav_type") @db.VarChar(20)  // header|hamburger|footer|side

  // ヒーロー
  heroType        String   @default("image") @map("hero_type") @db.VarChar(20)  // image|slideshow|video|text
  heroImageUrl    String?  @map("hero_image_url") @db.Text
  heroImages      Json?    @map("hero_images")                                    // スライドショー用URL配列
  heroVideoUrl    String?  @map("hero_video_url") @db.Text
  heroTitle       String?  @map("hero_title") @db.VarChar(200)
  heroSubtitle    String?  @map("hero_subtitle") @db.Text
  heroOverlayColor   String?  @default("rgba(0,0,0,0.5)") @map("hero_overlay_color") @db.VarChar(50)
  heroOverlayOpacity Decimal? @default(0.5) @map("hero_overlay_opacity") @db.Decimal(3, 2)
  heroTextAlign   String   @default("center") @map("hero_text_align") @db.VarChar(10) // left|center|right

  // アニメーション
  animationLevel  String   @default("subtle") @map("animation_level") @db.VarChar(20) // none|subtle|standard

  // Google Map
  mapStyle        String   @default("default") @map("map_style") @db.VarChar(20) // default|mono|dark
  mapZoom         Int      @default(15) @map("map_zoom")

  // フッター
  footerLayout    String   @default("1col") @map("footer_layout") @db.VarChar(10) // 1col|2col|3col
  footerSns       Json?    @map("footer_sns")  // [{type: 'instagram', url: '...'}, ...]
  showPoweredBy   Boolean  @default(true) @map("show_powered_by")

  // セクション設定（JSONで柔軟に）
  sectionConfig   Json?    @map("section_config")
  // 例: { features: { columns: 3, cardStyle: 'border', bgColor: '#fff' }, menus: { count: 4, style: 'grid' } }

  // SEO・ドメイン
  customDomain    String?  @map("custom_domain") @db.VarChar(255)
  metaTitle       String?  @map("meta_title") @db.VarChar(100)
  metaDescription String?  @map("meta_description") @db.VarChar(300)
  ogImageUrl      String?  @map("og_image_url") @db.Text

  // カスタムコード（プロプラン）
  gaTrackingId    String?  @map("ga_tracking_id") @db.VarChar(20)
  customCss       String?  @map("custom_css") @db.Text
  customHeadHtml  String?  @map("custom_head_html") @db.Text

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hp_settings")
}

model HpPage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String   @db.VarChar(50)
  title        String   @db.VarChar(200)
  content      Json
  isPublished  Boolean  @default(true) @map("is_published")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@map("hp_pages")
}

model BlogPost {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  title        String    @db.VarChar(200)
  slug         String    @db.VarChar(200)
  content      String    @db.Text
  thumbnailUrl String?   @map("thumbnail_url") @db.Text
  category     String?   @db.VarChar(50)
  isPublished  Boolean   @default(false) @map("is_published")
  publishedAt  DateTime? @map("published_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, isPublished, publishedAt])
  @@map("blog_posts")
}

// ==========================================
// 通知ログ
// ==========================================

model NotificationLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  customerId    String?  @map("customer_id") @db.Uuid
  reservationId String?  @map("reservation_id") @db.Uuid
  type          String   @db.VarChar(30)
  channel       String   @db.VarChar(20)
  status        String   @default("sent") @db.VarChar(20)
  sentAt        DateTime @default(now()) @map("sent_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

// ==========================================
// フォローアップ
// ==========================================

model FollowUpRule {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  name             String   @db.VarChar(100)
  triggerType      String   @map("trigger_type") @db.VarChar(30)
  intervalDays     Int?     @map("interval_days")
  symptomKeyword   String?  @map("symptom_keyword") @db.VarChar(200)
  seasonMonth      Int?     @map("season_month")
  seasonDay        Int?     @map("season_day")
  daysBeforeExpiry Int?     @map("days_before_expiry")
  subject          String   @db.VarChar(200)
  bodyTemplate     String   @map("body_template") @db.Text
  channel          String   @default("email") @db.VarChar(20)
  isActive         Boolean  @default(true) @map("is_active")
  isPreset         Boolean  @default(false) @map("is_preset")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs   FollowUpLog[]

  @@index([tenantId])
  @@map("follow_up_rules")
}

model FollowUpLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  channel     String   @db.VarChar(20)
  status      String   @default("sent") @db.VarChar(20)
  sentAt      DateTime @default(now()) @map("sent_at") @db.Timestamptz()
  errorDetail String?  @map("error_detail") @db.Text

  rule FollowUpRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([customerId])
  @@map("follow_up_logs")
}

// ==========================================
// LINE連携
// ==========================================

model LineConfig {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @unique @map("tenant_id") @db.Uuid
  channelId          String   @map("channel_id") @db.VarChar(50)
  channelSecret      String   @map("channel_secret") @db.VarChar(100)
  channelAccessToken String   @map("channel_access_token") @db.Text
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("line_configs")
}

model ChatMessage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  direction     String   @db.VarChar(10)
  messageType   String   @map("message_type") @db.VarChar(20)
  content       String   @db.Text
  lineMessageId String?  @map("line_message_id") @db.VarChar(100)
  sentAt        DateTime @default(now()) @map("sent_at") @db.Timestamptz()

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, sentAt])
  @@map("chat_messages")
}

// ==========================================
// プラットフォーム（ミナオスなび）
// ==========================================

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  customerId  String?  @map("customer_id") @db.Uuid
  authorName  String   @map("author_name") @db.VarChar(100)
  rating      Int
  title       String?  @db.VarChar(200)
  content     String   @db.Text
  isApproved  Boolean  @default(false) @map("is_approved")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isPublished])
  @@map("reviews")
}

model PlatformBoost {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  boostType String   @map("boost_type") @db.VarChar(30)
  startsAt  DateTime @map("starts_at") @db.Timestamptz()
  endsAt    DateTime @map("ends_at") @db.Timestamptz()
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive, endsAt])
  @@map("platform_boosts")
}

// 有料掲載院（ReserveHub非利用）
model PaidListing {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(100)
  email          String   @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  postalCode     String?  @map("postal_code") @db.VarChar(10)
  address        String?  @db.Text
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  logoUrl        String?  @map("logo_url") @db.Text
  coverImageUrl  String?  @map("cover_image_url") @db.Text
  description    String?  @db.Text
  symptoms       String[] @default([])
  website        String?  @db.Text
  businessHoursJson Json? @map("business_hours_json")
  listingPlan    String   @default("basic") @map("listing_plan") @db.VarChar(20) // basic|premium
  isActive       Boolean  @default(true) @map("is_active")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz()
  stripeCustomerId String? @map("stripe_customer_id") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("paid_listings")
}

// ==========================================
// プラットフォームユーザー（患者側アカウント）
// ==========================================

model PlatformUser {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @unique @map("user_id") @db.Uuid  // Supabase Auth user
  name        String   @db.VarChar(100)
  email       String   @unique @db.VarChar(255)
  birthDate   DateTime? @map("birth_date") @db.Date
  phone       String?  @db.VarChar(20)
  gender      String?  @db.VarChar(10)
  avatarUrl   String?  @map("avatar_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  favorites       PlatformFavorite[]
  disclosureRules PlatformDisclosure[]

  @@map("platform_users")
}

// お気に入り
model PlatformFavorite {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId String   @map("platform_user_id") @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid  // ReserveHub院
  paidListingId  String?  @map("paid_listing_id") @db.Uuid  // 有料掲載院
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([platformUserId, tenantId])
  @@map("platform_favorites")
}

// 情報開示設定（院ごとに開示範囲を管理）
model PlatformDisclosure {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformUserId String  @map("platform_user_id") @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid  // 開示先の院

  // 開示項目（チェックボックスでオンオフ）
  discloseName      Boolean @default(false) @map("disclose_name")
  discloseBirthDate Boolean @default(false) @map("disclose_birth_date")
  disclosePhone     Boolean @default(false) @map("disclose_phone")
  discloseGender    Boolean @default(false) @map("disclose_gender")
  discloseCarteData Boolean @default(false) @map("disclose_carte_data")  // 主訴・施術部位・施術内容（院名は含まない）
  discloseVisitHistory Boolean @default(false) @map("disclose_visit_history")  // 過去の施術部位・問診情報（院名は開示しない）

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([platformUserId, tenantId])
  @@map("platform_disclosures")
}
